<Window
    x:Class="AudioPilot.PackagedAppPickerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Select Packaged App"
    Width="620"
    Height="520"
    MinWidth="620"
    MinHeight="520"
    Background="{DynamicResource WindowBackgroundBrush}"
    Foreground="{DynamicResource TextBrush}"
    PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown"
    WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Foreground="{DynamicResource MutedTextBrush}"
            Text="Choose an installed Microsoft Store or UWP app. The picker inserts the app's AUMID into the routine trigger automatically."
            TextWrapping="Wrap" />

        <StackPanel Grid.Row="1" Margin="0,12,0,12">
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Search" />
                <TextBlock
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    Foreground="{DynamicResource MutedTextBrush}"
                    Text="{Binding FilteredAppCountText}" />
            </Grid>
            <TextBox
                x:Name="SearchTextBox"
                Height="32"
                Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <Border
            x:Name="AppsFrame"
            Grid.Row="2"
            Background="{DynamicResource ControlBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Focusable="False">
            <Grid>
                <ListBox
                    x:Name="AppsList"
                    MaxHeight="300"
                    Margin="0"
                    Padding="0"
                    AlternationCount="4096"
                    ItemsSource="{Binding FilteredApps}"
                    MouseDoubleClick="AppsList_MouseDoubleClick"
                    ScrollViewer.CanContentScroll="True"
                    SelectedItem="{Binding SelectedApp, Mode=TwoWay}"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.ScrollUnit="Pixel"
                    VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemContainerStyle>
                        <Style BasedOn="{StaticResource {x:Type ListBoxItem}}" TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border
                                x:Name="ItemSeparatorBorder"
                                Padding="10,8"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,0">
                                <StackPanel>
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="{Binding DisplayName}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        Foreground="{DynamicResource MutedTextBrush}"
                                        Text="{Binding AppUserModelId}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=(ItemsControl.AlternationIndex)}" Value="0">
                                    <Setter TargetName="ItemSeparatorBorder" Property="Border.BorderThickness" Value="0" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock
                    Margin="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource MutedTextBrush}"
                    Text="No packaged apps were detected. If this looks wrong, reopen the picker after Store updates finish or paste the AUMID manually."
                    TextAlignment="Center"
                    TextWrapping="Wrap"
                    Visibility="{Binding HasNoFilteredApps, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>
        </Border>

        <StackPanel
            Grid.Row="3"
            Margin="0,14,0,0"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <Button
                x:Name="RefreshButton"
                Width="96"
                Margin="0,0,12,0"
                Click="Refresh_Click"
                Content="Refresh" />
            <Button
                x:Name="CancelButton"
                Width="96"
                Margin="0,0,12,0"
                Content="Cancel"
                IsCancel="True" />
            <Button
                x:Name="SelectButton"
                Width="96"
                Click="Select_Click"
                Content="Select"
                IsDefault="True"
                IsEnabled="{Binding CanConfirmSelection}" />
        </StackPanel>
    </Grid>
</Window>
