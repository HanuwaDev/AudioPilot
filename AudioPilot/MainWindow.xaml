<Window
    x:Class="AudioPilot.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="clr-namespace:AudioPilot.Behaviors"
    xmlns:h="clr-namespace:AudioPilot.Helpers"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:tb="http://www.hardcodet.net/taskbar"
    xmlns:vm="clr-namespace:AudioPilot.ViewModels"
    Title="AudioPilot"
    Width="462"
    Height="378"
    Background="{DynamicResource WindowBackgroundBrush}"
    Foreground="{DynamicResource TextBrush}"
    Icon="pack://application:,,,/Images/sound.ico"
    Opacity="0"
    ResizeMode="CanMinimize"
    ShowActivated="False"
    ShowInTaskbar="False"
    Visibility="Hidden"
    WindowState="Normal">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding MinimizeCommand}" />
        <KeyBinding
            Key="Tab"
            Command="{Binding NextSettingsTabCommand}"
            Modifiers="Control" />
        <KeyBinding
            Key="S"
            Command="{Binding SaveCurrentContextCommand}"
            Modifiers="Control" />
        <KeyBinding Key="F5" Command="{Binding RefreshDevicesCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <h:EnumDisplayNameConverter x:Key="EnumDisplayNameConverter" />
        <Style x:Key="SettingsRepoLinkStyle" TargetType="{x:Type Hyperlink}">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HotTrackBrushKey}}" />
            <Setter Property="TextDecorations" Value="Underline" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SettingsSectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="-2,0,0,6" />
        </Style>
        <Style x:Key="SettingsRolePillStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{DynamicResource AppFocusVisualStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border
                            x:Name="Bd"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SettingsVolumeExpanderStyle" TargetType="Expander">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                            <DockPanel>
                                <ToggleButton
                                    x:Name="HeaderToggle"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Content="{TemplateBinding Header}"
                                    DockPanel.Dock="Top"
                                    FocusVisualStyle="{DynamicResource AppFocusVisualStyle}"
                                    Focusable="True"
                                    IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                    OverridesDefaultStyle="True">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Padding="10,8" Background="{DynamicResource ControlBackgroundBrush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Path
                                                        x:Name="ArrowGlyph"
                                                        Grid.Column="0"
                                                        Width="10"
                                                        Height="10"
                                                        Margin="0,0,8,0"
                                                        VerticalAlignment="Center"
                                                        Data="M 0 0 L 10 0 L 5 6 Z"
                                                        Fill="{DynamicResource TextBrush}" />
                                                    <ContentPresenter
                                                        Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        ContentSource="Content"
                                                        RecognizesAccessKey="True" />
                                                </Grid>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="ArrowGlyph" Property="Data" Value="M 0 6 L 10 6 L 5 0 Z" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ArrowGlyph" Property="Fill" Value="{DynamicResource AccentBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <ContentPresenter
                                    x:Name="ExpandSite"
                                    Margin="10,0,10,10"
                                    Focusable="False"
                                    Visibility="Collapsed" />
                            </DockPanel>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ResetButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ResetButtonBackgroundBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ResetButtonHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ResetButtonPressedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <SolidColorBrush x:Key="RoutineSucceededBrush" Color="#2F855A" />
        <SolidColorBrush x:Key="RoutineWaitingBrush" Color="#C27D0E" />
        <SolidColorBrush x:Key="RoutineFailedBrush" Color="#C05621" />
        <SolidColorBrush x:Key="RoutineSkippedBrush" Color="#5F6B7A" />

        <Style x:Key="RoutineHotkeyWarningTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource HotkeyConflictBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="{x:Static vm:HotkeyWarningKind.Reserved}">
                    <Setter Property="Foreground" Value="{DynamicResource HotkeyReservedBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="{x:Static vm:HotkeyWarningKind.Fallback}">
                    <Setter Property="Foreground" Value="{DynamicResource HotkeyFallbackBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <ContextMenu x:Key="HotkeyDeleteContextMenu" Style="{DynamicResource AppContextMenuStyle}">
            <MenuItem
                Click="ClearHotkeyText_Click"
                Header="Delete"
                InputGestureText="Del"
                Style="{DynamicResource AppContextMenuItemStyle}" />
        </ContextMenu>

        <ContextMenu x:Key="EditableTextContextMenu" Style="{DynamicResource AppContextMenuStyle}">
            <MenuItem
                Command="ApplicationCommands.Undo"
                CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                Header="Undo"
                Style="{DynamicResource AppContextMenuItemStyle}" />
            <MenuItem
                Command="ApplicationCommands.Redo"
                CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                Header="Redo"
                Style="{DynamicResource AppContextMenuItemStyle}" />
            <Separator Style="{DynamicResource AppContextMenuSeparatorStyle}" />
            <MenuItem
                Command="ApplicationCommands.Cut"
                CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                Header="Cut"
                Style="{DynamicResource AppContextMenuItemStyle}" />
            <MenuItem
                Command="ApplicationCommands.Copy"
                CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                Header="Copy"
                Style="{DynamicResource AppContextMenuItemStyle}" />
            <MenuItem
                Command="ApplicationCommands.Paste"
                CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                Header="Paste"
                Style="{DynamicResource AppContextMenuItemStyle}" />
            <MenuItem
                Click="ClearEditableText_Click"
                Header="Delete"
                InputGestureText="Del"
                Style="{DynamicResource AppContextMenuItemStyle}" />
            <Separator Style="{DynamicResource AppContextMenuSeparatorStyle}" />
            <MenuItem
                Command="ApplicationCommands.SelectAll"
                CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                Header="Select All"
                Style="{DynamicResource AppContextMenuItemStyle}" />
        </ContextMenu>
    </Window.Resources>

    <Grid Background="Transparent" PreviewMouseDown="RootGrid_PreviewMouseDown">
        <ScrollViewer x:Name="MainContentScrollViewer" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Label
                        HorizontalAlignment="Center"
                        Content="Audio Switcher"
                        FontSize="18"
                        FontWeight="Bold"
                        Visibility="{Binding IsEditorTabsActive, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <Label
                        HorizontalAlignment="Center"
                        Content="Routines"
                        FontSize="18"
                        FontWeight="Bold"
                        Visibility="{Binding IsRoutinesTabActive, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <Label
                        HorizontalAlignment="Center"
                        Content="App Settings"
                        FontSize="18"
                        FontWeight="Bold"
                        Visibility="{Binding IsSettingsTabActive, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <TabControl
                        x:Name="DeviceTabControl"
                        Width="400"
                        Margin="0,6,0,0"
                        HorizontalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        SelectedIndex="{Binding SelectedSettingsTabIndex, Mode=TwoWay}"
                        SelectionChanged="DeviceTabControl_SelectionChanged">
                        <TabControl.Resources>
                            <Style TargetType="TabPanel">
                                <Setter Property="HorizontalAlignment" Value="Center" />
                            </Style>
                        </TabControl.Resources>
                        <TabItem Header="Output">
                            <StackPanel Margin="10">
                                <Label Content="Available Output Devices:" />
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox
                                        Name="AvailableOutputDeviceComboBox"
                                        Width="300"
                                        ItemsSource="{Binding AvailableOutputDeviceNames}"
                                        SelectedIndex="{Binding SelectedAvailableOutputIndex, Mode=TwoWay}" />
                                    <Button
                                        Width="62"
                                        Margin="8,0,0,0"
                                        Command="{Binding AddOutputCycleDeviceCommand}"
                                        Content="Add" />
                                </StackPanel>

                                <Label Content="Output Switch Order:" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="300" />
                                        <ColumnDefinition Width="72" />
                                    </Grid.ColumnDefinitions>

                                    <ListBox
                                        x:Name="OutputSwitchOrderListBox"
                                        Grid.Column="0"
                                        Height="104"
                                        DisplayMemberPath="DisplayName"
                                        ItemsSource="{Binding OutputCycleDevices}"
                                        SelectedIndex="{Binding SelectedOutputCycleIndex, Mode=TwoWay}"
                                        SelectionMode="Extended">
                                        <ListBox.InputBindings>
                                            <KeyBinding
                                                Key="W"
                                                Command="{Binding RemoveOutputCycleDeviceCommand}"
                                                Modifiers="Control" />
                                            <KeyBinding
                                                Key="Up"
                                                Command="{Binding MoveOutputCycleDeviceUpCommand}"
                                                Modifiers="Alt" />
                                            <KeyBinding
                                                Key="Down"
                                                Command="{Binding MoveOutputCycleDeviceDownCommand}"
                                                Modifiers="Alt" />
                                        </ListBox.InputBindings>
                                        <i:Interaction.Behaviors>
                                            <b:ListBoxSelectedItemsBehavior SelectedItems="{Binding SelectedOutputCycleDevices}" />
                                        </i:Interaction.Behaviors>
                                    </ListBox>

                                    <StackPanel
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center">
                                        <Button
                                            Height="30"
                                            Margin="0,0,0,4"
                                            Command="{Binding MoveOutputCycleDeviceUpCommand}"
                                            Content="Up" />
                                        <Button
                                            Height="30"
                                            Margin="0,0,0,4"
                                            Command="{Binding MoveOutputCycleDeviceDownCommand}"
                                            Content="Down" />
                                        <Button
                                            Height="30"
                                            Command="{Binding RemoveOutputCycleDeviceCommand}"
                                            Content="Remove" />
                                    </StackPanel>
                                </Grid>

                                <Label Content="Hotkey:" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="300" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox
                                        Name="HotkeyTextBox"
                                        Grid.Column="0"
                                        ContextMenu="{StaticResource HotkeyDeleteContextMenu}"
                                        IsEnabled="{Binding OutputHotkeysEnabled, Mode=TwoWay}"
                                        Text="{Binding Hotkey.DisplayText, Mode=OneWay}">
                                        <i:Interaction.Behaviors>
                                            <b:PlaceholderExampleBehavior
                                                Identity="output-hotkey"
                                                Options="Ctrl+Alt+O|Alt+Period|Ctrl+Alt+Right"
                                                PreferredFamily="letter" />
                                            <b:HoverInfoPopupBehavior Text="{Binding Hotkey.HoverText}" WarningKind="{Binding Hotkey.WarningKind}" />
                                            <b:HotkeyCaptureBehavior Target="{Binding Hotkey}" />
                                            <b:HotkeyWarningBorderBehavior HasWarning="{Binding Hotkey.HasWarning}" WarningKind="{Binding Hotkey.WarningKind}" />
                                        </i:Interaction.Behaviors>
                                    </TextBox>

                                    <CheckBox
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Content="Enabled"
                                        IsChecked="{Binding OutputHotkeysEnabled, Mode=TwoWay}" />
                                </Grid>

                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Input">
                            <StackPanel Margin="10">
                                <Label Content="Available Input Devices:" />
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox
                                        Name="AvailableInputDeviceComboBox"
                                        Width="300"
                                        ItemsSource="{Binding AvailableInputDeviceNames}"
                                        SelectedIndex="{Binding SelectedAvailableInputIndex, Mode=TwoWay}" />
                                    <Button
                                        Width="62"
                                        Margin="8,0,0,0"
                                        Command="{Binding AddInputCycleDeviceCommand}"
                                        Content="Add" />
                                </StackPanel>

                                <Label Content="Input Switch Order:" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="300" />
                                        <ColumnDefinition Width="72" />
                                    </Grid.ColumnDefinitions>

                                    <ListBox
                                        x:Name="InputSwitchOrderListBox"
                                        Grid.Column="0"
                                        Height="104"
                                        DisplayMemberPath="DisplayName"
                                        ItemsSource="{Binding InputCycleDevices}"
                                        SelectedIndex="{Binding SelectedInputCycleIndex, Mode=TwoWay}"
                                        SelectionMode="Extended">
                                        <ListBox.InputBindings>
                                            <KeyBinding
                                                Key="W"
                                                Command="{Binding RemoveInputCycleDeviceCommand}"
                                                Modifiers="Control" />
                                            <KeyBinding
                                                Key="Up"
                                                Command="{Binding MoveInputCycleDeviceUpCommand}"
                                                Modifiers="Alt" />
                                            <KeyBinding
                                                Key="Down"
                                                Command="{Binding MoveInputCycleDeviceDownCommand}"
                                                Modifiers="Alt" />
                                        </ListBox.InputBindings>
                                        <i:Interaction.Behaviors>
                                            <b:ListBoxSelectedItemsBehavior SelectedItems="{Binding SelectedInputCycleDevices}" />
                                        </i:Interaction.Behaviors>
                                    </ListBox>

                                    <StackPanel
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center">
                                        <Button
                                            Height="30"
                                            Margin="0,0,0,4"
                                            Command="{Binding MoveInputCycleDeviceUpCommand}"
                                            Content="Up" />
                                        <Button
                                            Height="30"
                                            Margin="0,0,0,4"
                                            Command="{Binding MoveInputCycleDeviceDownCommand}"
                                            Content="Down" />
                                        <Button
                                            Height="30"
                                            Command="{Binding RemoveInputCycleDeviceCommand}"
                                            Content="Remove" />
                                    </StackPanel>
                                </Grid>

                                <Label Content="Hotkey:" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="300" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox
                                        Name="InputHotkeyTextBox"
                                        Grid.Column="0"
                                        ContextMenu="{StaticResource HotkeyDeleteContextMenu}"
                                        IsEnabled="{Binding InputHotkeysEnabled, Mode=TwoWay}"
                                        Text="{Binding InputHotkey.DisplayText, Mode=OneWay}">
                                        <i:Interaction.Behaviors>
                                            <b:PlaceholderExampleBehavior
                                                Identity="input-hotkey"
                                                Options="Ctrl+Alt+I|Alt+Comma|Ctrl+Alt+Left"
                                                PreferredFamily="letter" />
                                            <b:HoverInfoPopupBehavior Text="{Binding InputHotkey.HoverText}" WarningKind="{Binding InputHotkey.WarningKind}" />
                                            <b:HotkeyCaptureBehavior Target="{Binding InputHotkey}" />
                                            <b:HotkeyWarningBorderBehavior HasWarning="{Binding InputHotkey.HasWarning}" WarningKind="{Binding InputHotkey.WarningKind}" />
                                        </i:Interaction.Behaviors>
                                    </TextBox>

                                    <CheckBox
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Content="Enabled"
                                        IsChecked="{Binding InputHotkeysEnabled, Mode=TwoWay}" />
                                </Grid>

                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Routines">
                            <StackPanel Margin="10">
                                <TextBlock
                                    Margin="0,0,0,8"
                                    Foreground="{DynamicResource MutedTextBrush}"
                                    Text="Routines help automatically switch the devices you want when the conditions you choose are met."
                                    TextWrapping="Wrap" />

                                <StackPanel>
                                    <TextBlock
                                        Margin="0,0,0,4"
                                        FontWeight="SemiBold"
                                        Text="Saved routines" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="300" />
                                            <ColumnDefinition Width="72" />
                                        </Grid.ColumnDefinitions>

                                        <ListBox
                                            x:Name="SavedRoutinesListBox"
                                            Grid.Column="0"
                                            Height="111"
                                            ItemsSource="{Binding Routines}"
                                            PreviewMouseRightButtonDown="SavedRoutinesListBox_PreviewMouseRightButtonDown"
                                            ScrollViewer.CanContentScroll="True"
                                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                                            SelectedIndex="{Binding SelectedRoutineIndex, Mode=TwoWay}"
                                            SelectionMode="Extended"
                                            VirtualizingPanel.IsVirtualizing="True"
                                            VirtualizingPanel.ScrollUnit="Pixel"
                                            VirtualizingPanel.VirtualizationMode="Recycling">
                                            <i:Interaction.Behaviors>
                                                <b:ListBoxSelectedItemsBehavior SelectedItems="{Binding SelectedRoutines}" />
                                            </i:Interaction.Behaviors>
                                            <ListBox.ContextMenu>
                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}" Style="{DynamicResource AppContextMenuStyle}">
                                                    <MenuItem
                                                        Command="{Binding DuplicateRoutineCommand}"
                                                        Header="Duplicate"
                                                        Style="{DynamicResource AppContextMenuItemStyle}" />
                                                    <MenuItem
                                                        Command="{Binding CopyRoutineCommand}"
                                                        Header="Copy"
                                                        Style="{DynamicResource AppContextMenuItemStyle}" />
                                                </ContextMenu>
                                            </ListBox.ContextMenu>
                                            <ListBox.InputBindings>
                                                <KeyBinding
                                                    Key="W"
                                                    Command="{Binding RemoveRoutineCommand}"
                                                    Modifiers="Control" />
                                                <KeyBinding
                                                    Key="Up"
                                                    Command="{Binding MoveRoutineUpCommand}"
                                                    Modifiers="Alt" />
                                                <KeyBinding
                                                    Key="Down"
                                                    Command="{Binding MoveRoutineDownCommand}"
                                                    Modifiers="Alt" />
                                            </ListBox.InputBindings>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,0,0,1">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Opacity" Value="1" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                                        <Setter Property="Opacity" Value="0.58" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>

                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock
                                                                Grid.Column="0"
                                                                Margin="0,0,6,0"
                                                                FontSize="12"
                                                                FontWeight="SemiBold"
                                                                Text="{Binding DisplayName}"
                                                                TextTrimming="CharacterEllipsis" />

                                                            <StackPanel
                                                                Grid.Column="1"
                                                                VerticalAlignment="Center"
                                                                Orientation="Horizontal">
                                                                <Border
                                                                    Margin="0,0,4,0"
                                                                    Padding="6,1"
                                                                    Background="{DynamicResource ControlHoverBrush}"
                                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="9">
                                                                    <TextBlock
                                                                        FontSize="10"
                                                                        FontWeight="SemiBold"
                                                                        Foreground="{DynamicResource MutedTextBrush}"
                                                                        Text="{Binding TargetKindBadgeText}" />
                                                                </Border>

                                                                <Border
                                                                    Padding="6,1"
                                                                    Background="{DynamicResource ResetButtonBackgroundBrush}"
                                                                    BorderBrush="Transparent"
                                                                    BorderThickness="0"
                                                                    CornerRadius="9">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock
                                                                        FontSize="10"
                                                                        FontWeight="SemiBold"
                                                                        Foreground="White"
                                                                        Text="Disabled" />
                                                                </Border>

                                                                <Border
                                                                    Margin="4,0,0,0"
                                                                    Padding="6,1"
                                                                    BorderBrush="Transparent"
                                                                    BorderThickness="0"
                                                                    CornerRadius="9">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Setter Property="Background" Value="{StaticResource RoutineSucceededBrush}" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasLastRunBadge}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding LastRunState}" Value="WaitingForApp">
                                                                                    <Setter Property="Background" Value="{StaticResource RoutineWaitingBrush}" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding LastRunState}" Value="Failed">
                                                                                    <Setter Property="Background" Value="{StaticResource RoutineFailedBrush}" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding LastRunState}" Value="Skipped">
                                                                                    <Setter Property="Background" Value="{StaticResource RoutineSkippedBrush}" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock
                                                                        FontSize="10"
                                                                        FontWeight="SemiBold"
                                                                        Foreground="White"
                                                                        Text="{Binding LastRunBadgeText}" />
                                                                </Border>
                                                            </StackPanel>
                                                        </Grid>

                                                        <TextBlock
                                                            FontSize="11"
                                                            Foreground="{DynamicResource MutedTextBrush}"
                                                            Text="{Binding TriggerSummary}"
                                                            TextTrimming="CharacterEllipsis" />

                                                        <TextBlock
                                                            FontSize="10"
                                                            Foreground="{DynamicResource MutedTextBrush}"
                                                            Text="{Binding LastRunStatusText}"
                                                            TextTrimming="CharacterEllipsis" />

                                                        <TextBlock
                                                            FontSize="10"
                                                            Foreground="{DynamicResource HotkeyConflictBrush}"
                                                            Text="{Binding ConflictSummary}"
                                                            TextWrapping="Wrap">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasConflict}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>

                                                        <TextBlock
                                                            FontSize="10"
                                                            Tag="{Binding HotkeyWarningKind}"
                                                            Text="{Binding HotkeyWarningSummary}"
                                                            TextWrapping="Wrap">
                                                            <TextBlock.Style>
                                                                <Style BasedOn="{StaticResource RoutineHotkeyWarningTextStyle}" TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasHotkeyWarning}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <StackPanel
                                            Grid.Column="1"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center">
