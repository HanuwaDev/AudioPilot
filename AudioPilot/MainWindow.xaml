                                                                    <b:PlaceholderExampleBehavior Identity="master-volume-up-hotkey" PreferredFamily="wheel-up" Options="Ctrl+PageUp|Ctrl+Alt+Up|Alt+WheelUp" />
                                                                    <b:HoverInfoPopupBehavior Text="{Binding SettingsMasterVolumeUpHotkeyDraftCapture.HoverText}" WarningKind="{Binding SettingsMasterVolumeUpHotkeyDraftCapture.WarningKind}" />
                                                                    <b:HotkeyCaptureBehavior Target="{Binding SettingsMasterVolumeUpHotkeyDraftCapture}" />
                                                                    <b:HotkeyWarningBorderBehavior HasWarning="{Binding SettingsMasterVolumeUpHotkeyDraftCapture.HasWarning}" WarningKind="{Binding SettingsMasterVolumeUpHotkeyDraftCapture.WarningKind}" />
                                                                </i:Interaction.Behaviors>
                                                            </TextBox>
                                                     </StackPanel>

                                                     <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                         <Label Content="Master Volume Down:"
                                                             Width="150"
                                                             VerticalAlignment="Center" />
                                                            <TextBox Width="170"
                                                                     Text="{Binding SettingsMasterVolumeDownHotkeyDraftCapture.DisplayText, Mode=OneWay}"
                                                                     ContextMenu="{StaticResource HotkeyDeleteContextMenu}">
                                                                <i:Interaction.Behaviors>
                                                                    <b:PlaceholderExampleBehavior Identity="master-volume-down-hotkey" PreferredFamily="wheel-down" Options="Ctrl+PageDown|Ctrl+Alt+Down|Alt+WheelDown" />
                                                                    <b:HoverInfoPopupBehavior Text="{Binding SettingsMasterVolumeDownHotkeyDraftCapture.HoverText}" WarningKind="{Binding SettingsMasterVolumeDownHotkeyDraftCapture.WarningKind}" />
                                                                    <b:HotkeyCaptureBehavior Target="{Binding SettingsMasterVolumeDownHotkeyDraftCapture}" />
                                                                    <b:HotkeyWarningBorderBehavior HasWarning="{Binding SettingsMasterVolumeDownHotkeyDraftCapture.HasWarning}" WarningKind="{Binding SettingsMasterVolumeDownHotkeyDraftCapture.WarningKind}" />
                                                                </i:Interaction.Behaviors>
                                                            </TextBox>
                                                     </StackPanel>

                                                     <StackPanel Orientation="Horizontal">
                                                         <Label Content="Master Step (%):"
                                                             Width="150"
                                                             VerticalAlignment="Center" />
                                                         <TextBox Width="80"
                                                                  Text="{Binding SettingsMasterVolumeStepPercentDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                            <i:Interaction.Behaviors>
                                                                <b:HoverInfoPopupBehavior Text="Sets how much each master volume hotkey press changes the default output volume. Use 1 to 100." />
                                                            </i:Interaction.Behaviors>
                                                         </TextBox>
                                                         <TextBlock Text="(1 to 100)"
                                                                    Foreground="{DynamicResource MutedTextBrush}"
                                                                    VerticalAlignment="Center"
                                                                    Margin="8,0,0,0" />
                                                     </StackPanel>
                                                 </StackPanel>
                                             </Expander>

                                             <Expander IsExpanded="{Binding SettingsMicVolumeControlsExpanded, Mode=TwoWay}"
                                                       Style="{StaticResource SettingsVolumeExpanderStyle}">
                                                 <Expander.Header>
                                                     <TextBlock Text="Microphone Volume"
                                                                FontWeight="SemiBold" />
                                                 </Expander.Header>
                                                 <StackPanel>
                                                     <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                         <Label Content="Mic Volume Up:"
                                                             Width="150"
                                                             VerticalAlignment="Center" />
                                                            <TextBox Width="170"
                                                                     Text="{Binding SettingsMicVolumeUpHotkeyDraftCapture.DisplayText, Mode=OneWay}"
                                                                     ContextMenu="{StaticResource HotkeyDeleteContextMenu}">
                                                                <i:Interaction.Behaviors>
                                                                    <b:PlaceholderExampleBehavior Identity="mic-volume-up-hotkey" PreferredFamily="wheel-up" Options="Ctrl+Home|Ctrl+Shift+Up|Alt+WheelUp" />
                                                                    <b:HoverInfoPopupBehavior Text="{Binding SettingsMicVolumeUpHotkeyDraftCapture.HoverText}" WarningKind="{Binding SettingsMicVolumeUpHotkeyDraftCapture.WarningKind}" />
                                                                    <b:HotkeyCaptureBehavior Target="{Binding SettingsMicVolumeUpHotkeyDraftCapture}" />
                                                                    <b:HotkeyWarningBorderBehavior HasWarning="{Binding SettingsMicVolumeUpHotkeyDraftCapture.HasWarning}" WarningKind="{Binding SettingsMicVolumeUpHotkeyDraftCapture.WarningKind}" />
                                                                </i:Interaction.Behaviors>
                                                            </TextBox>
                                                     </StackPanel>

                                                     <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                         <Label Content="Mic Volume Down:"
                                                             Width="150"
                                                             VerticalAlignment="Center" />
                                                            <TextBox Width="170"
                                                                     Text="{Binding SettingsMicVolumeDownHotkeyDraftCapture.DisplayText, Mode=OneWay}"
                                                                     ContextMenu="{StaticResource HotkeyDeleteContextMenu}">
                                                                <i:Interaction.Behaviors>
                                                                    <b:PlaceholderExampleBehavior Identity="mic-volume-down-hotkey" PreferredFamily="wheel-down" Options="Ctrl+End|Ctrl+Shift+Down|Alt+WheelDown" />
                                                                    <b:HoverInfoPopupBehavior Text="{Binding SettingsMicVolumeDownHotkeyDraftCapture.HoverText}" WarningKind="{Binding SettingsMicVolumeDownHotkeyDraftCapture.WarningKind}" />
                                                                    <b:HotkeyCaptureBehavior Target="{Binding SettingsMicVolumeDownHotkeyDraftCapture}" />
                                                                    <b:HotkeyWarningBorderBehavior HasWarning="{Binding SettingsMicVolumeDownHotkeyDraftCapture.HasWarning}" WarningKind="{Binding SettingsMicVolumeDownHotkeyDraftCapture.WarningKind}" />
                                                                </i:Interaction.Behaviors>
                                                            </TextBox>
                                                     </StackPanel>

                                                     <StackPanel Orientation="Horizontal">
                                                         <Label Content="Mic Step (%):"
                                                             Width="150"
                                                             VerticalAlignment="Center" />
                                                         <TextBox Width="80"
                                                                  Text="{Binding SettingsMicVolumeStepPercentDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                            <i:Interaction.Behaviors>
                                                                <b:HoverInfoPopupBehavior Text="Sets how much each mic volume hotkey press changes the default microphone volume. Use 1 to 100." />
                                                            </i:Interaction.Behaviors>
                                                         </TextBox>
                                                         <TextBlock Text="(1 to 100)"
                                                                    Foreground="{DynamicResource MutedTextBrush}"
                                                                    VerticalAlignment="Center"
                                                                    Margin="8,0,0,0" />
                                                     </StackPanel>
                                                 </StackPanel>
                                             </Expander>
                                         </StackPanel>

                                 <TextBlock Text="Overlay"
                                            Style="{StaticResource SettingsSectionHeaderStyle}" />

                                 <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <CheckBox Content="Enable overlays"
                                                  IsChecked="{Binding SettingsOverlayEnabledDraft, Mode=TwoWay}">
                                            <i:Interaction.Behaviors>
                                                <b:HoverInfoPopupBehavior Text="Shows on-screen overlays for media, mute, and device switching actions." />
                                            </i:Interaction.Behaviors>
                                        </CheckBox>
                                    </StackPanel>

                                 <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Label Content="Overlay Position:"
                                               Width="150"
                                               VerticalAlignment="Center" />
                                        <ComboBox ItemsSource="{Binding AvailableOverlayPositions}"
                                                  SelectedItem="{Binding SettingsOverlayPositionDraft, Mode=TwoWay}"
                                                  IsEnabled="{Binding SettingsOverlayEnabledDraft, Mode=OneWay}"
                                         Width="170">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource EnumDisplayNameConverter}}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                                        <Label Content="Overlay Duration (s):"
                                               Width="150"
                                               VerticalAlignment="Center" />
                                     <TextBox Width="80"
                                                 IsEnabled="{Binding SettingsOverlayEnabledDraft, Mode=OneWay}"
                                                 Text="{Binding SettingsOverlayDurationSecondsDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                        <i:Interaction.Behaviors>
                                            <b:HoverInfoPopupBehavior Text="How long the overlay stays visible in seconds (0.5 to 10)." />
                                        </i:Interaction.Behaviors>
                                    </TextBox>
                                     <TextBlock Text="(0.5 to 10)"
                                          Foreground="{DynamicResource MutedTextBrush}"
                                          VerticalAlignment="Center"
                                          Margin="8,0,0,0" />
                                    </StackPanel>

                                     <TextBlock Text="Miscellaneous"
                                             Style="{StaticResource SettingsSectionHeaderStyle}" />

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <CheckBox Content="Preserve audio levels"
                                                  IsChecked="{Binding SettingsPreserveAudioLevelsDraft, Mode=TwoWay}"
                                                  Margin="0,0,14,0">
                                            <i:Interaction.Behaviors>
                                                <b:HoverInfoPopupBehavior Text="Preserves current per-process and mixer volume levels when switching output devices." />
                                            </i:Interaction.Behaviors>
                                        </CheckBox>

                                        <CheckBox Content="Auto-scroll to mixer on restore"
                                                  IsChecked="{Binding SettingsAutoScrollToMixerOnRestoreDraft, Mode=TwoWay}">
                                            <i:Interaction.Behaviors>
                                                <b:HoverInfoPopupBehavior Text="Automatically scrolls to the&#10;&quot;Volume Mixer&quot; when the&#10;app window is restored." />
                                            </i:Interaction.Behaviors>
                                        </CheckBox>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Label Content="Device reference:"
                                               Width="150"
                                               VerticalAlignment="Center" />
                                        <ComboBox ItemsSource="{Binding AvailableDeviceReferenceFileModes}"
                                                  SelectedItem="{Binding SettingsDeviceReferenceFileModeDraft, Mode=TwoWay}"
                                                  Width="170">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource EnumDisplayNameConverter}}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                            <i:Interaction.Behaviors>
                                                <b:HoverInfoPopupBehavior Text="Controls what DEVICES.txt contains: Off disables file generation, Plaintext includes real device IDs and names, and Hashed includes device names with anonymized IDs." />
                                            </i:Interaction.Behaviors>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                                        <Label Content="Log Level:"
                                               Width="150"
                                             VerticalAlignment="Center" />
                                        <ComboBox ItemsSource="{Binding AvailableLogLevels}"
                                                  SelectedItem="{Binding SettingsLogLevelDraft, Mode=TwoWay}"
                                                  Width="170">
                                            <i:Interaction.Behaviors>
                                                <b:HoverInfoPopupBehavior Text="Choose how detailed logs are.&#10;None disables logging and removes&#10;existing log files when applied." />
                                            </i:Interaction.Behaviors>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                                        <CheckBox Content="Redact sensitive log content"
                                                  IsChecked="{Binding SettingsRedactLogContentDraft, Mode=TwoWay}"
                                                  Margin="0,0,20,0">
                                            <i:Interaction.Behaviors>
                                                <b:HoverInfoPopupBehavior Text="Enabled keeps sensitive values anonymized in app logs.&#10;Disable this only if you explicitly want raw device names, paths, ids, and similar content written to the log file." />
                                            </i:Interaction.Behaviors>
                                        </CheckBox>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <CheckBox Content="Enable auto-save"
                                                      IsChecked="{Binding SettingsAutoSaveEnabledDraft, Mode=TwoWay}"
                                                      VerticalAlignment="Center">
                                                <i:Interaction.Behaviors>
                                                    <b:HoverInfoPopupBehavior Text="Enable to automatically save device, hotkey, routine, and settings changes." />
                                                </i:Interaction.Behaviors>
                                            </CheckBox>
                                        </StackPanel>
                                    </StackPanel>

                                        <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                        <Button Content="Import Settings"
                                                Width="105"
                                            Margin="0,0,8,0"
                                            Command="{Binding ImportSettingsCommand}" />
                                            <Button Content="Apply Settings"
                                                Width="130"
                                                Margin="0,0,8,0"
                                                Command="{Binding ApplySettingsCommand}" />
                                        <Button Content="Export Settings"
                                                Width="105"
                                            Command="{Binding ExportSettingsCommand}" />
                                        </StackPanel>
                                    </StackPanel>
                        </TabItem>
                    </TabControl>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="10"
                                Visibility="{Binding IsEditorTabsActive, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button Content="Refresh"
                                Command="{Binding RefreshDevicesCommand}"
                                Margin="5" />
                        <Button Content="Save Settings"
                                Command="{Binding SaveSettingsCommand}"
                                Margin="5" />
                        <CheckBox Content="Run at Startup"
                                  IsChecked="{Binding RunAtStartup, Mode=TwoWay}"
                              Margin="5,5,0,5" />
                        <ComboBox ItemsSource="{Binding AvailableThemes}"
                                  SelectedItem="{Binding Theme, Mode=TwoWay}"
                                  Width="70"
                                  Margin="9,5,0,5" />
                    </StackPanel>

                </StackPanel>

                  <Label x:Name="VolumeMixerHeader"
                      Content="{Binding ActiveMixerHeader}"
                       FontSize="18"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Visibility="{Binding IsEditorTabsActive, Converter={StaticResource BoolToVisibilityConverter}}" />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Visibility="{Binding IsEditorTabsActive, Converter={StaticResource BoolToVisibilityConverter}}">
                    <CheckBox Content="Mute Mic"
                              IsChecked="{Binding MuteMic, Mode=TwoWay}"
                              Margin="5" />
                    <CheckBox Content="Deafen"
                              IsChecked="{Binding Deafen, Mode=TwoWay}"
                              Margin="5" />
                    <CheckBox Content="Mute Sound"
                              IsChecked="{Binding MuteSound, Mode=TwoWay}"
                              Margin="5" />
                </StackPanel>

                <ListBox Name="VolumeMixer"
                         ItemsSource="{Binding ActiveMixerSessions}"
                         Visibility="{Binding IsEditorTabsActive, Converter={StaticResource BoolToVisibilityConverter}}"
                         SelectionChanged="VolumeMixer_SelectionChanged"
                         PreviewMouseWheel="VolumeMixer_PreviewMouseWheel"
                         KeyboardNavigation.TabNavigation="Continue"
                         IsTabStop="False"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.CanContentScroll="True"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Pixel">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Focusable" Value="False" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Label Grid.Column="0"
                                       Margin="0,0,20,0"
                                        Width="175"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap">
                                        <i:Interaction.Behaviors>
                                            <b:TrimmedTextPopupBehavior />
                                        </i:Interaction.Behaviors>
                                    </TextBlock>
                                    <Label.Style>
                                        <Style TargetType="{x:Type Label}" BasedOn="{StaticResource {x:Type Label}}">
                                            <Setter Property="FontWeight" Value="Normal" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMaster}" Value="True">
                                                    <Setter Property="FontWeight" Value="Bold" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsMic}" Value="True">
                                                    <Setter Property="FontWeight" Value="Bold" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsSystemSounds}" Value="True">
                                                    <Setter Property="FontWeight" Value="Bold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Label.Style>
                                </Label>

                                <Slider Grid.Column="1"
                                    Width="130"
                                        Maximum="100"
                                        VerticalAlignment="Center"
                                        IsMoveToPointEnabled="True"
                                        Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <i:Interaction.Behaviors>
                                        <b:SliderValuePopupBehavior HorizontalOffset="0"
                                                                    VerticalOffset="-28" />
                                    </i:Interaction.Behaviors>
                                </Slider>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Visibility="{Binding IsEditorTabsActive, Converter={StaticResource BoolToVisibilityConverter}}"
                            Margin="8,1,0,10">
                    <Button Content="Reset to Defaults"
                            Command="{Binding ResetToDefaultsCommand}"
                            Margin="2"
                            Style="{StaticResource ResetButtonStyle}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <tb:TaskbarIcon x:Name="taskbarIcon"
                        ToolTipText="AudioPilot"
                        IconSource="pack://application:,,,/Images/sound.ico"
                        TrayRightMouseUp="TaskbarIcon_TrayRightMouseUp"
                        TrayMouseDoubleClick="TaskbarIcon_TrayMouseDoubleClick"
                        ContextMenu="{x:Null}">
        </tb:TaskbarIcon>
    </Grid>
</Window>
