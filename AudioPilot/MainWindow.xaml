                                            Content="Add" />
                                        <Button
                                            Width="50"
                                            Margin="0,0,6,0"
                                            Command="{Binding EditRoutineCommand}"
                                            Content="Edit" />
                                        <Button
                                            Width="60"
                                            Margin="0,0,6,0"
                                            Command="{Binding EnableSelectedRoutinesCommand}"
                                            Content="Enable" />
                                        <Button
                                            Width="60"
                                            Margin="0,0,6,0"
                                            Command="{Binding DisableSelectedRoutinesCommand}"
                                            Content="Disable" />
