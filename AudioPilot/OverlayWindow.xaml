<Window x:Class="AudioPilot.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        MinHeight="100"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        IsHitTestVisible="False"
        Opacity="1">

    <Window.Resources>
        <Storyboard x:Key="FadeOutStoryboard">
            <DoubleAnimation
                Storyboard.TargetProperty="Opacity"
                To="0"
                Duration="0:0:0.5"
                FillBehavior="Stop"/>
        </Storyboard>
    </Window.Resources>

    <Border Background="{DynamicResource OverlayBackgroundBrush}" CornerRadius="8" Padding="10" Margin="10">
        <TextBlock x:Name="OverlayText"
                   Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                   FontSize="16"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"/>
    </Border>
</Window>
