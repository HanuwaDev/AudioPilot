                                            Margin="0,2,0,0"
                                            Style="{StaticResource RoutineHotkeyWarningTextStyle}"
                                            Tag="{Binding SelectedRoutine.HotkeyWarningKind}"
                                            Text="{Binding SelectedRoutine.HotkeyWarningSummary}"
                                            TextWrapping="Wrap"
                                            Visibility="{Binding SelectedRoutine.HasHotkeyWarning, Converter={StaticResource BoolToVisibilityConverter}}" />

                                        <TextBlock
                                            Margin="0,6,0,0"
                                            FontWeight="SemiBold"
                                            Text="Application target"
                                            Visibility="{Binding SelectedRoutine.HasApplicationTrigger, Converter={StaticResource BoolToVisibilityConverter}}" />
