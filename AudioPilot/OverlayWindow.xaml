<Window
    x:Class="AudioPilot.OverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="clr-namespace:AudioPilot.Services.UI"
    MinHeight="100"
    AllowsTransparency="True"
    Background="Transparent"
    IsHitTestVisible="False"
    Opacity="1"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    Topmost="True"
    WindowStartupLocation="Manual"
    WindowStyle="None">

    <Window.Resources>
        <Storyboard x:Key="FadeOutStoryboard">
            <DoubleAnimation
                FillBehavior="Stop"
                Storyboard.TargetProperty="Opacity"
                To="0"
                Duration="0:0:0.5" />
        </Storyboard>
    </Window.Resources>

    <Border
        Margin="10"
        Padding="10"
        Background="{DynamicResource OverlayBackgroundBrush}"
        CornerRadius="8">
        <Grid>
            <TextBlock
                x:Name="OverlayText"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="16"
                Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                TextAlignment="Center"
                TextTrimming="CharacterEllipsis"
                TextWrapping="Wrap" />

            <StackPanel
                x:Name="StructuredOverlayPanel"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Visibility="Collapsed">
                <TextBlock
                    x:Name="StructuredHeaderText"
                    HorizontalAlignment="Stretch"
                    FontSize="15"
                    FontWeight="Bold"
                    Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap" />
                <Grid
                    x:Name="StructuredRow1"
                    Margin="0,4,0,0"
                    Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Name="StructuredRow1LabelText"
                        Grid.Column="0"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                        TextAlignment="Right"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />
                    <TextBlock
                        x:Name="StructuredRow1ValueText"
                        Grid.Column="1"
                        MaxHeight="60"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                        LineHeight="20"
                        LineStackingStrategy="BlockLineHeight"
                        TextAlignment="Center"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="Wrap" />
                </Grid>
                <Grid
                    x:Name="StructuredRow2"
                    Margin="0,3,0,0"
                    Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Name="StructuredRow2LabelText"
                        Grid.Column="0"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                        TextAlignment="Right"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />
                    <TextBlock
                        x:Name="StructuredRow2ValueText"
                        Grid.Column="1"
                        MaxHeight="60"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                        LineHeight="20"
                        LineStackingStrategy="BlockLineHeight"
                        TextAlignment="Center"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="Wrap" />
                </Grid>
                <Grid
                    x:Name="StructuredRow3"
                    Margin="0,3,0,0"
                    Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Name="StructuredRow3LabelText"
                        Grid.Column="0"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                        TextAlignment="Right"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />
                    <TextBlock
                        x:Name="StructuredRow3ValueText"
                        Grid.Column="1"
                        MaxHeight="60"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                        LineHeight="20"
                        LineStackingStrategy="BlockLineHeight"
                        TextAlignment="Center"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="Wrap" />
                </Grid>
                <Grid
                    x:Name="StructuredRow4"
                    Margin="0,3,0,0"
                    Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Name="StructuredRow4LabelText"
                        Grid.Column="0"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                        TextAlignment="Right"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />
                    <TextBlock
                        x:Name="StructuredRow4ValueText"
                        Grid.Column="1"
                        MaxHeight="60"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                        LineHeight="20"
                        LineStackingStrategy="BlockLineHeight"
                        TextAlignment="Center"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="Wrap" />
                </Grid>
            </StackPanel>

            <StackPanel
                x:Name="MediaOverlayPanel"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Visibility="Collapsed">
                <TextBlock
                    x:Name="MediaHeaderText"
                    HorizontalAlignment="Stretch"
                    FontSize="15"
                    FontWeight="Bold"
                    Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap" />
                <ui:MediaOverlayInlineTextBlock
                    x:Name="MediaTitleText"
                    Margin="0,4,0,0"
                    HorizontalAlignment="Stretch"
                    MaxHeight="63"
                    FontSize="17"
                    FontWeight="Bold"
                    Foreground="{DynamicResource OverlayOutputDeviceBrush}"
                    LineHeight="21"
                    MaxLines="3" />
                <ui:MediaOverlayInlineTextBlock
                    x:Name="MediaArtistText"
                    Margin="0,3,0,0"
                    HorizontalAlignment="Stretch"
                    MaxHeight="38"
                    FontSize="15"
                    FontWeight="Bold"
                    Foreground="{DynamicResource OverlayInputDeviceBrush}"
                    LineHeight="19"
                    MaxLines="2" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
