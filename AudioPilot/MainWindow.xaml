                                            Margin="0,2,0,6"
                                            Text="{Binding SelectedRoutine.OutputDeviceName}"
                                            TextWrapping="Wrap"
                                            Visibility="{Binding SelectedRoutine.HasOutputTarget, Converter={StaticResource BoolToVisibilityConverter}}" />

                                        <TextBlock
                                            FontWeight="SemiBold"
                                            Text="Input"
                                            Visibility="{Binding SelectedRoutine.HasInputTarget, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <TextBlock
                                            Margin="0,2,0,6"
                                            Text="{Binding SelectedRoutine.InputDeviceName}"
                                            TextWrapping="Wrap"
                                            Visibility="{Binding SelectedRoutine.HasInputTarget, Converter={StaticResource BoolToVisibilityConverter}}" />

                                        <TextBlock
                                            FontWeight="SemiBold"
                                            Text="Master volume"
                                            Visibility="{Binding SelectedRoutine.HasMasterVolumeTarget, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <TextBlock
                                            Margin="0,2,0,6"
                                            Text="{Binding SelectedRoutine.MasterVolumePercent, StringFormat={}{0}%}"
                                            TextWrapping="Wrap"
                                            Visibility="{Binding SelectedRoutine.HasMasterVolumeTarget, Converter={StaticResource BoolToVisibilityConverter}}" />

                                        <TextBlock
                                            FontWeight="SemiBold"
                                            Text="Microphone volume"
                                            Visibility="{Binding SelectedRoutine.HasMicVolumeTarget, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <TextBlock
                                            Margin="0,2,0,6"
                                            Text="{Binding SelectedRoutine.MicVolumePercent, StringFormat={}{0}%}"
                                            TextWrapping="Wrap"
                                            Visibility="{Binding SelectedRoutine.HasMicVolumeTarget, Converter={StaticResource BoolToVisibilityConverter}}" />

                                        <TextBlock FontWeight="SemiBold" Text="Triggers" />
                                        <TextBlock
                                            Margin="0,2,0,0"
                                            Text="{Binding SelectedRoutine.RoutineDetailsTriggerSummary}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            Margin="0,2,0,0"
                                            Text="{Binding SelectedRoutine.ScheduleTimeZoneDisplay, StringFormat='Time zone: {0}'}"
                                            TextWrapping="Wrap"
                                            Visibility="{Binding SelectedRoutine.HasScheduledTrigger, Converter={StaticResource BoolToVisibilityConverter}}" />

                                        <TextBlock
                                            Margin="0,6,0,0"
                                            FontWeight="SemiBold"
                                            Text="Options"
                                            Visibility="{Binding SelectedRoutine.HasRoutineDetailsOptions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <TextBlock
                                            Margin="0,2,0,0"
                                            Text="{Binding SelectedRoutine.RoutineDetailsOptionsSummary}"
                                            TextWrapping="Wrap"
                                            Visibility="{Binding SelectedRoutine.HasRoutineDetailsOptions, Converter={StaticResource BoolToVisibilityConverter}}" />

                                        <TextBlock
                                            Margin="0,6,0,0"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource HotkeyConflictBrush}"
                                            Text="Conflict warning"
                                            Visibility="{Binding SelectedRoutine.HasConflict, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <TextBlock
                                            Margin="0,2,0,0"
                                            Foreground="{DynamicResource HotkeyConflictBrush}"
                                            Text="{Binding SelectedRoutine.ConflictSummary}"
                                            TextWrapping="Wrap"
                                            Visibility="{Binding SelectedRoutine.HasConflict, Converter={StaticResource BoolToVisibilityConverter}}" />

                                        <TextBlock
                                            Margin="0,6,0,0"
                                            FontWeight="SemiBold"
                                            Style="{StaticResource RoutineHotkeyWarningTextStyle}"
                                            Tag="{Binding SelectedRoutine.HotkeyWarningKind}"
                                            Text="Hotkey warning"
                                            Visibility="{Binding SelectedRoutine.HasHotkeyWarning, Converter={StaticResource BoolToVisibilityConverter}}" />
