<Window x:Class="AudioPilot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:b="clr-namespace:AudioPilot.Behaviors"
        xmlns:h="clr-namespace:AudioPilot.Helpers"
        xmlns:vm="clr-namespace:AudioPilot.ViewModels"
        Title="AudioPilot"
        Height="378"
        Width="462"
        WindowState="Normal"
        Visibility="Hidden"
        ShowInTaskbar="False"
        ShowActivated="False"
        Opacity="0"
        ResizeMode="CanMinimize"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}"
        Icon="pack://application:,,,/Images/sound.ico">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding MinimizeCommand}" />
        <KeyBinding Key="Tab" Modifiers="Control" Command="{Binding NextSettingsTabCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCurrentContextCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshDevicesCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <h:EnumDisplayNameConverter x:Key="EnumDisplayNameConverter" />
        <Style x:Key="SettingsRepoLinkStyle" TargetType="{x:Type Hyperlink}">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HotTrackBrushKey}}" />
            <Setter Property="TextDecorations" Value="Underline" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SettingsSectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="-2,0,0,6" />
        </Style>
        <Style x:Key="SettingsRolePillStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SettingsVolumeExpanderStyle" TargetType="Expander">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <DockPanel>
                                <ToggleButton x:Name="HeaderToggle"
                                              DockPanel.Dock="Top"
                                              Content="{TemplateBinding Header}"
                                              Focusable="False"
                                              OverridesDefaultStyle="True"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Padding="10,8"
                                                    Background="{DynamicResource ControlBackgroundBrush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Path x:Name="ArrowGlyph"
                                                          Grid.Column="0"
                                                          Width="10"
                                                          Height="10"
                                                          Margin="0,0,8,0"
                                                          VerticalAlignment="Center"
                                                          Fill="{DynamicResource TextBrush}"
                                                          Data="M 0 0 L 10 0 L 5 6 Z" />
                                                    <ContentPresenter Grid.Column="1"
                                                                      VerticalAlignment="Center"
                                                                      ContentSource="Content"
                                                                      RecognizesAccessKey="True" />
                                                </Grid>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="ArrowGlyph" Property="Data" Value="M 0 6 L 10 6 L 5 0 Z" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ArrowGlyph" Property="Fill" Value="{DynamicResource AccentBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <ContentPresenter x:Name="ExpandSite"
                                                  Margin="10,0,10,10"
                                                  Visibility="Collapsed"
                                                  Focusable="False" />
                            </DockPanel>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ResetButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ResetButtonBackgroundBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ResetButtonHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ResetButtonPressedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <SolidColorBrush x:Key="RoutineSucceededBrush" Color="#2F855A" />
        <SolidColorBrush x:Key="RoutineWaitingBrush" Color="#C27D0E" />
        <SolidColorBrush x:Key="RoutineFailedBrush" Color="#C05621" />
        <SolidColorBrush x:Key="RoutineSkippedBrush" Color="#5F6B7A" />

        <Style x:Key="RoutineHotkeyWarningTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource HotkeyConflictBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="{x:Static vm:HotkeyWarningKind.Reserved}">
                    <Setter Property="Foreground" Value="{DynamicResource HotkeyReservedBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="{x:Static vm:HotkeyWarningKind.Fallback}">
                    <Setter Property="Foreground" Value="{DynamicResource HotkeyFallbackBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <ContextMenu x:Key="HotkeyDeleteContextMenu" Style="{DynamicResource AppContextMenuStyle}">
            <MenuItem Header="Delete"
                      InputGestureText="Delete"
                      Click="ClearHotkeyText_Click"
                      Style="{DynamicResource AppContextMenuItemStyle}" />
        </ContextMenu>
    </Window.Resources>

    <Grid Background="Transparent"
          PreviewMouseDown="RootGrid_PreviewMouseDown">
        <ScrollViewer x:Name="MainContentScrollViewer" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Label Content="Audio Switcher"
                           FontSize="18"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Visibility="{Binding IsEditorTabsActive, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <Label Content="Routines"
                           FontSize="18"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Visibility="{Binding IsRoutinesTabActive, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <Label Content="App Settings"
                          FontSize="18"
                          FontWeight="Bold"
                          HorizontalAlignment="Center"
                          Visibility="{Binding IsSettingsTabActive, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <TabControl x:Name="DeviceTabControl"
                                Margin="0,6,0,0"
                                Width="400"
                                HorizontalAlignment="Center"
                                SelectedIndex="{Binding SelectedSettingsTabIndex, Mode=TwoWay}"
                                SelectionChanged="DeviceTabControl_SelectionChanged"
                                BorderThickness="0"
                                Background="Transparent">
                        <TabControl.Resources>
                            <Style TargetType="TabPanel">
                                <Setter Property="HorizontalAlignment" Value="Center" />
                            </Style>
                        </TabControl.Resources>
                        <TabItem Header="Output">
                            <StackPanel Margin="10">
                                <Label Content="Available Output Devices:" />
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox Name="AvailableOutputDeviceComboBox"
                                              Width="300"
                                              ItemsSource="{Binding AvailableOutputDeviceNames}"
                                              SelectedIndex="{Binding SelectedAvailableOutputIndex, Mode=TwoWay}" />
                                    <Button Content="Add"
                                            Width="62"
                                            Margin="8,0,0,0"
                                            Command="{Binding AddOutputCycleDeviceCommand}" />
                                </StackPanel>

                                <Label Content="Output Switch Order:" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="300" />
                                        <ColumnDefinition Width="72" />
                                    </Grid.ColumnDefinitions>

                                    <ListBox x:Name="OutputSwitchOrderListBox"
                                             Grid.Column="0"
                                             Height="104"
                                             ItemsSource="{Binding OutputCycleDevices}"
                                             DisplayMemberPath="DisplayName"
                                             SelectionMode="Extended"
                                             SelectedIndex="{Binding SelectedOutputCycleIndex, Mode=TwoWay}">
                                        <ListBox.InputBindings>
                                            <KeyBinding Key="W"
                                                        Modifiers="Control"
                                                        Command="{Binding RemoveOutputCycleDeviceCommand}" />
                                            <KeyBinding Key="Up"
                                                        Modifiers="Alt"
                                                        Command="{Binding MoveOutputCycleDeviceUpCommand}" />
                                            <KeyBinding Key="Down"
                                                        Modifiers="Alt"
                                                        Command="{Binding MoveOutputCycleDeviceDownCommand}" />
                                        </ListBox.InputBindings>
                                        <i:Interaction.Behaviors>
                                            <b:ListBoxSelectedItemsBehavior SelectedItems="{Binding SelectedOutputCycleDevices}" />
                                        </i:Interaction.Behaviors>
                                    </ListBox>

                                    <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                        <Button Content="Up"
                                                Height="30"
                                                Margin="0,0,0,4"
                                                Command="{Binding MoveOutputCycleDeviceUpCommand}" />
                                        <Button Content="Down"
                                                Height="30"
                                                Margin="0,0,0,4"
                                                Command="{Binding MoveOutputCycleDeviceDownCommand}" />
                                        <Button Content="Remove"
                                                Height="30"
                                                Command="{Binding RemoveOutputCycleDeviceCommand}" />
                                    </StackPanel>
                                </Grid>

                                <Label Content="Hotkey:" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="300" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Name="HotkeyTextBox"
                                             Grid.Column="0"
                                             Text="{Binding Hotkey.DisplayText, Mode=OneWay}"
                                             IsEnabled="{Binding OutputHotkeysEnabled, Mode=TwoWay}"
                                             ContextMenu="{StaticResource HotkeyDeleteContextMenu}">
                                        <i:Interaction.Behaviors>
                                            <b:PlaceholderExampleBehavior Identity="output-hotkey" PreferredFamily="letter" Options="Ctrl+Alt+O|Alt+Period|Ctrl+Alt+Right" />
                                            <b:HoverInfoPopupBehavior Text="{Binding Hotkey.HoverText}" WarningKind="{Binding Hotkey.WarningKind}" />
                                            <b:HotkeyCaptureBehavior Target="{Binding Hotkey}" />
                                            <b:HotkeyWarningBorderBehavior HasWarning="{Binding Hotkey.HasWarning}" WarningKind="{Binding Hotkey.WarningKind}" />
                                        </i:Interaction.Behaviors>
                                    </TextBox>

                                    <CheckBox Grid.Column="1"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              Content="Enabled"
                                              IsChecked="{Binding OutputHotkeysEnabled, Mode=TwoWay}" />
                                </Grid>

                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Input">
                            <StackPanel Margin="10">
                                <Label Content="Available Input Devices:" />
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox Name="AvailableInputDeviceComboBox"
                                              Width="300"
                                              ItemsSource="{Binding AvailableInputDeviceNames}"
                                              SelectedIndex="{Binding SelectedAvailableInputIndex, Mode=TwoWay}" />
                                    <Button Content="Add"
                                            Width="62"
                                            Margin="8,0,0,0"
                                            Command="{Binding AddInputCycleDeviceCommand}" />
                                </StackPanel>

                                <Label Content="Input Switch Order:" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="300" />
                                        <ColumnDefinition Width="72" />
                                    </Grid.ColumnDefinitions>

                                    <ListBox x:Name="InputSwitchOrderListBox"
                                             Grid.Column="0"
                                             Height="104"
                                             ItemsSource="{Binding InputCycleDevices}"
                                             DisplayMemberPath="DisplayName"
                                             SelectionMode="Extended"
                                             SelectedIndex="{Binding SelectedInputCycleIndex, Mode=TwoWay}">
                                        <ListBox.InputBindings>
                                            <KeyBinding Key="W"
                                                        Modifiers="Control"
                                                        Command="{Binding RemoveInputCycleDeviceCommand}" />
                                            <KeyBinding Key="Up"
                                                        Modifiers="Alt"
                                                        Command="{Binding MoveInputCycleDeviceUpCommand}" />
                                            <KeyBinding Key="Down"
                                                        Modifiers="Alt"
                                                        Command="{Binding MoveInputCycleDeviceDownCommand}" />
                                        </ListBox.InputBindings>
                                        <i:Interaction.Behaviors>
                                            <b:ListBoxSelectedItemsBehavior SelectedItems="{Binding SelectedInputCycleDevices}" />
                                        </i:Interaction.Behaviors>
                                    </ListBox>

                                    <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                        <Button Content="Up"
                                                Height="30"
                                                Margin="0,0,0,4"
                                                Command="{Binding MoveInputCycleDeviceUpCommand}" />
                                        <Button Content="Down"
                                                Height="30"
                                                Margin="0,0,0,4"
                                                Command="{Binding MoveInputCycleDeviceDownCommand}" />
                                        <Button Content="Remove"
                                                Height="30"
                                                Command="{Binding RemoveInputCycleDeviceCommand}" />
                                    </StackPanel>
                                </Grid>

                                <Label Content="Hotkey:" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="300" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Name="InputHotkeyTextBox"
                                             Grid.Column="0"
                                             Text="{Binding InputHotkey.DisplayText, Mode=OneWay}"
                                             IsEnabled="{Binding InputHotkeysEnabled, Mode=TwoWay}"
                                             ContextMenu="{StaticResource HotkeyDeleteContextMenu}">
                                        <i:Interaction.Behaviors>
                                            <b:PlaceholderExampleBehavior Identity="input-hotkey" PreferredFamily="letter" Options="Ctrl+Alt+I|Alt+Comma|Ctrl+Alt+Left" />
                                            <b:HoverInfoPopupBehavior Text="{Binding InputHotkey.HoverText}" WarningKind="{Binding InputHotkey.WarningKind}" />
                                            <b:HotkeyCaptureBehavior Target="{Binding InputHotkey}" />
                                            <b:HotkeyWarningBorderBehavior HasWarning="{Binding InputHotkey.HasWarning}" WarningKind="{Binding InputHotkey.WarningKind}" />
                                        </i:Interaction.Behaviors>
                                    </TextBox>

                                    <CheckBox Grid.Column="1"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              Content="Enabled"
                                              IsChecked="{Binding InputHotkeysEnabled, Mode=TwoWay}" />
                                </Grid>

                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Routines">
                            <StackPanel Margin="10">
                                <TextBlock Text="Routines help automatically switch the devices you want when the conditions you choose are met."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           Margin="0,0,0,8" />

                                <StackPanel>
                                    <TextBlock Text="Saved routines"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="300" />
                                            <ColumnDefinition Width="72" />
                                        </Grid.ColumnDefinitions>

                                        <ListBox x:Name="SavedRoutinesListBox"
                                                 Grid.Column="0"
                                                 Height="111"
                                                 ItemsSource="{Binding Routines}"
                                                 SelectionMode="Extended"
                                                 SelectedIndex="{Binding SelectedRoutineIndex, Mode=TwoWay}"
                                                 PreviewMouseRightButtonDown="SavedRoutinesListBox_PreviewMouseRightButtonDown"
                                                 ScrollViewer.CanContentScroll="True"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 VirtualizingPanel.IsVirtualizing="True"
                                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                                 VirtualizingPanel.ScrollUnit="Pixel">
                                            <i:Interaction.Behaviors>
                                                <b:ListBoxSelectedItemsBehavior SelectedItems="{Binding SelectedRoutines}" />
                                            </i:Interaction.Behaviors>
                                            <ListBox.ContextMenu>
                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                             Style="{DynamicResource AppContextMenuStyle}">
                                                    <MenuItem Header="Duplicate"
                                                              Command="{Binding DuplicateRoutineCommand}"
                                                              Style="{DynamicResource AppContextMenuItemStyle}" />
                                                    <MenuItem Header="Copy"
                                                              Command="{Binding CopyRoutineCommand}"
                                                              Style="{DynamicResource AppContextMenuItemStyle}" />
                                                </ContextMenu>
                                            </ListBox.ContextMenu>
                                            <ListBox.InputBindings>
                                                <KeyBinding Key="W"
                                                            Modifiers="Control"
                                                            Command="{Binding RemoveRoutineCommand}" />
                                                <KeyBinding Key="Up"
                                                            Modifiers="Alt"
                                                            Command="{Binding MoveRoutineUpCommand}" />
                                                <KeyBinding Key="Down"
                                                            Modifiers="Alt"
                                                            Command="{Binding MoveRoutineDownCommand}" />
                                            </ListBox.InputBindings>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,0,0,1">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Opacity" Value="1" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                                        <Setter Property="Opacity" Value="0.58" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>

                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding DisplayName}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="12"
                                                                       Margin="0,0,6,0"
                                                                       TextTrimming="CharacterEllipsis" />

                                                            <StackPanel Grid.Column="1"
                                                                        Orientation="Horizontal"
                                                                        VerticalAlignment="Center">
                                                                <Border Background="{DynamicResource ControlHoverBrush}"
                                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="9"
                                                                        Padding="6,1"
                                                                        Margin="0,0,4,0">
                                                                    <TextBlock Text="{Binding TargetKindBadgeText}"
                                                                               FontSize="10"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource MutedTextBrush}" />
                                                                </Border>

                                                                <Border Background="{DynamicResource ResetButtonBackgroundBrush}"
                                                                        BorderBrush="Transparent"
                                                                        BorderThickness="0"
                                                                        CornerRadius="9"
                                                                        Padding="6,1">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock Text="Disabled"
                                                                               FontSize="10"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="White" />
                                                                </Border>

                                                                <Border BorderBrush="Transparent"
                                                                        BorderThickness="0"
                                                                        CornerRadius="9"
                                                                        Padding="6,1"
                                                                        Margin="4,0,0,0">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Setter Property="Background" Value="{StaticResource RoutineSucceededBrush}" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasLastRunBadge}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding LastRunState}" Value="WaitingForApp">
                                                                                    <Setter Property="Background" Value="{StaticResource RoutineWaitingBrush}" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding LastRunState}" Value="Failed">
                                                                                    <Setter Property="Background" Value="{StaticResource RoutineFailedBrush}" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding LastRunState}" Value="Skipped">
                                                                                    <Setter Property="Background" Value="{StaticResource RoutineSkippedBrush}" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock Text="{Binding LastRunBadgeText}"
                                                                               FontSize="10"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="White" />
                                                                </Border>
                                                            </StackPanel>
                                                        </Grid>

                                                        <TextBlock Text="{Binding TriggerSummary}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                                   TextTrimming="CharacterEllipsis" />

                                                        <TextBlock Text="{Binding LastRunStatusText}"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                                   TextTrimming="CharacterEllipsis" />

                                                        <TextBlock Text="{Binding ConflictSummary}"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource HotkeyConflictBrush}"
                                                                   TextWrapping="Wrap">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasConflict}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>

                                                            <TextBlock Text="{Binding HotkeyWarningSummary}"
                                                                       Tag="{Binding HotkeyWarningKind}"
                                                                       FontSize="10"
                                                                       TextWrapping="Wrap">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource RoutineHotkeyWarningTextStyle}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasHotkeyWarning}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <StackPanel Grid.Column="1"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center">
                                            <Button Content="Up"
                                                    Height="30"
                                                    Margin="0,0,0,4"
                                                    Command="{Binding MoveRoutineUpCommand}" />
                                            <Button Content="Down"
                                                    Height="30"
                                                    Margin="0,0,0,4"
                                                    Command="{Binding MoveRoutineDownCommand}" />
                                            <Button Content="Remove"
                                                    Height="30"
                                                    Command="{Binding RemoveRoutineCommand}" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                Margin="0,6,0,10">
                                        <Button Content="Add"
                                                Width="50"
                                                Margin="0,0,6,0"
                                                Command="{Binding AddRoutineCommand}" />
                                        <Button Content="Edit"
                                                Width="50"
                                                Margin="0,0,6,0"
                                                Command="{Binding EditRoutineCommand}" />
                                        <Button Content="Enable"
                                            Width="60"
