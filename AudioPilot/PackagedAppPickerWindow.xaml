<Window x:Class="AudioPilot.PackagedAppPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Packaged App"
        Width="620"
        Height="520"
        MinWidth="620"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
               Text="Choose an installed Microsoft Store or UWP app. The picker inserts the app's AUMID into the routine trigger automatically."
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource MutedTextBrush}" />

        <StackPanel Grid.Row="1"
                    Margin="0,12,0,12">
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Search" />
                <TextBlock Grid.Column="1"
                           Text="{Binding FilteredAppCountText}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           HorizontalAlignment="Right" />
            </Grid>
            <TextBox x:Name="SearchTextBox"
                     Height="32"
                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <Border x:Name="AppsFrame"
            Grid.Row="2"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Background="{DynamicResource ControlBackgroundBrush}"
            Focusable="True">
            <Grid>
                <ListBox x:Name="AppsList"
                         Margin="0"
                         Padding="0"
                         MaxHeight="300"
                         AlternationCount="4096"
                         ScrollViewer.CanContentScroll="True"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Pixel"
                         ItemsSource="{Binding FilteredApps}"
                         SelectedItem="{Binding SelectedApp, Mode=TwoWay}"
                         MouseDoubleClick="AppsList_MouseDoubleClick">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem"
                               BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="ItemSeparatorBorder"
                                    Padding="10,8"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,1,0,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding AppUserModelId}"
                                               Margin="0,4,0,0"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=(ItemsControl.AlternationIndex)}"
                                             Value="0">
                                    <Setter TargetName="ItemSeparatorBorder" Property="Border.BorderThickness" Value="0" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Text="No packaged apps were detected. If this looks wrong, reopen the picker after Store updates finish or paste the AUMID manually."
                           Margin="24"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Visibility="{Binding HasNoFilteredApps, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,14,0,0">
            <TextBlock x:Name="RefreshStatusText"
                   Margin="0,0,12,0"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource MutedTextBrush}"
                   Text="Refreshing..."
                   Visibility="Collapsed" />
            <Button x:Name="RefreshButton"
                Content="Refresh"
                Width="96"
                Margin="0,0,12,0"
                Click="Refresh_Click" />
            <Button x:Name="CancelButton"
                Content="Cancel"
                    Width="96"
                    Margin="0,0,12,0"
                    IsCancel="True" />
            <Button x:Name="SelectButton"
                Content="Select"
                    Width="96"
                    IsDefault="True"
                    IsEnabled="{Binding CanConfirmSelection}"
                    Click="Select_Click" />
        </StackPanel>
    </Grid>
</Window>
