                                                Identity="mute-mic-hotkey"
                                                Options="Ctrl+Alt+M|Ctrl+Shift+M|Alt+MouseX1"
                                                PreferredFamily="letter" />
                                            <b:HoverInfoPopupBehavior Text="{Binding SettingsMuteMicHotkeyDraftCapture.HoverText}" WarningKind="{Binding SettingsMuteMicHotkeyDraftCapture.WarningKind}" />
                                            <b:HotkeyCaptureBehavior Target="{Binding SettingsMuteMicHotkeyDraftCapture}" />
                                            <b:HotkeyWarningBorderBehavior HasWarning="{Binding SettingsMuteMicHotkeyDraftCapture.HasWarning}" WarningKind="{Binding SettingsMuteMicHotkeyDraftCapture.WarningKind}" />
                                        </i:Interaction.Behaviors>
                                    </TextBox>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                    <Label
                                        Width="150"
                                        VerticalAlignment="Center"
                                        Content="Mute Sound:" />
                                    <TextBox
                                        Width="170"
                                        ContextMenu="{StaticResource HotkeyDeleteContextMenu}"
                                        Text="{Binding SettingsMuteSoundHotkeyDraftCapture.DisplayText, Mode=OneWay}">
                                        <i:Interaction.Behaviors>
                                            <b:PlaceholderExampleBehavior
                                                Identity="mute-sound-hotkey"
                                                Options="Ctrl+Alt+S|Ctrl+Shift+S|Alt+MouseX2"
                                                PreferredFamily="letter" />
                                            <b:HoverInfoPopupBehavior Text="{Binding SettingsMuteSoundHotkeyDraftCapture.HoverText}" WarningKind="{Binding SettingsMuteSoundHotkeyDraftCapture.WarningKind}" />
                                            <b:HotkeyCaptureBehavior Target="{Binding SettingsMuteSoundHotkeyDraftCapture}" />
                                            <b:HotkeyWarningBorderBehavior HasWarning="{Binding SettingsMuteSoundHotkeyDraftCapture.HasWarning}" WarningKind="{Binding SettingsMuteSoundHotkeyDraftCapture.WarningKind}" />
                                        </i:Interaction.Behaviors>
                                    </TextBox>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,14" Orientation="Horizontal">
                                    <Label
                                        Width="150"
                                        VerticalAlignment="Center"
                                        Content="Deafen:" />
                                    <TextBox
                                        Width="170"
                                        ContextMenu="{StaticResource HotkeyDeleteContextMenu}"
                                        Text="{Binding SettingsDeafenHotkeyDraftCapture.DisplayText, Mode=OneWay}">
                                        <i:Interaction.Behaviors>
                                            <b:PlaceholderExampleBehavior
                                                Identity="deafen-hotkey"
                                                Options="Ctrl+Alt+D|Ctrl+Shift+D|Alt+MouseMiddle"
                                                PreferredFamily="letter" />
                                            <b:HoverInfoPopupBehavior Text="{Binding SettingsDeafenHotkeyDraftCapture.HoverText}" WarningKind="{Binding SettingsDeafenHotkeyDraftCapture.WarningKind}" />
                                            <b:HotkeyCaptureBehavior Target="{Binding SettingsDeafenHotkeyDraftCapture}" />
                                            <b:HotkeyWarningBorderBehavior HasWarning="{Binding SettingsDeafenHotkeyDraftCapture.HasWarning}" WarningKind="{Binding SettingsDeafenHotkeyDraftCapture.WarningKind}" />
                                        </i:Interaction.Behaviors>
                                    </TextBox>
                                </StackPanel>

                                <TextBlock
                                    Margin="0,0,0,6"
                                    FontWeight="SemiBold"
                                    Text="Volume Controls" />

                                <StackPanel Margin="0,0,0,18">
                                    <Expander
                                        Margin="0,0,0,8"
                                        IsExpanded="{Binding SettingsMasterVolumeControlsExpanded, Mode=TwoWay}"
                                        Style="{StaticResource SettingsVolumeExpanderStyle}">
                                        <Expander.Header>
                                            <TextBlock FontWeight="SemiBold" Text="Master Volume" />
                                        </Expander.Header>
                                        <StackPanel>
                                            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                                <Label
                                                    Width="150"
                                                    VerticalAlignment="Center"
                                                    Content="Master Volume Up:" />
                                                <TextBox
                                                    Width="170"
                                                    ContextMenu="{StaticResource HotkeyDeleteContextMenu}"
                                                    Text="{Binding SettingsMasterVolumeUpHotkeyDraftCapture.DisplayText, Mode=OneWay}">
                                                    <i:Interaction.Behaviors>
                                                        <b:PlaceholderExampleBehavior
                                                            Identity="master-volume-up-hotkey"
                                                            Options="Ctrl+PageUp|Ctrl+Alt+Up|Alt+WheelUp"
                                                            PreferredFamily="wheel-up" />
                                                        <b:HoverInfoPopupBehavior Text="{Binding SettingsMasterVolumeUpHotkeyDraftCapture.HoverText}" WarningKind="{Binding SettingsMasterVolumeUpHotkeyDraftCapture.WarningKind}" />
                                                        <b:HotkeyCaptureBehavior Target="{Binding SettingsMasterVolumeUpHotkeyDraftCapture}" />
                                                        <b:HotkeyWarningBorderBehavior HasWarning="{Binding SettingsMasterVolumeUpHotkeyDraftCapture.HasWarning}" WarningKind="{Binding SettingsMasterVolumeUpHotkeyDraftCapture.WarningKind}" />
                                                    </i:Interaction.Behaviors>
                                                </TextBox>
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                                <Label
                                                    Width="150"
                                                    VerticalAlignment="Center"
                                                    Content="Master Volume Down:" />
                                                <TextBox
                                                    Width="170"
                                                    ContextMenu="{StaticResource HotkeyDeleteContextMenu}"
                                                    Text="{Binding SettingsMasterVolumeDownHotkeyDraftCapture.DisplayText, Mode=OneWay}">
                                                    <i:Interaction.Behaviors>
                                                        <b:PlaceholderExampleBehavior
                                                            Identity="master-volume-down-hotkey"
                                                            Options="Ctrl+PageDown|Ctrl+Alt+Down|Alt+WheelDown"
                                                            PreferredFamily="wheel-down" />
                                                        <b:HoverInfoPopupBehavior Text="{Binding SettingsMasterVolumeDownHotkeyDraftCapture.HoverText}" WarningKind="{Binding SettingsMasterVolumeDownHotkeyDraftCapture.WarningKind}" />
                                                        <b:HotkeyCaptureBehavior Target="{Binding SettingsMasterVolumeDownHotkeyDraftCapture}" />
                                                        <b:HotkeyWarningBorderBehavior HasWarning="{Binding SettingsMasterVolumeDownHotkeyDraftCapture.HasWarning}" WarningKind="{Binding SettingsMasterVolumeDownHotkeyDraftCapture.WarningKind}" />
                                                    </i:Interaction.Behaviors>
                                                </TextBox>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal">
                                                <Label
                                                    Width="150"
                                                    VerticalAlignment="Center"
                                                    Content="Master Step (%):" />
                                                <TextBox
                                                    Width="80"
                                                    b:TextBoxPlaceholderBehavior.Text="5"
                                                    ContextMenu="{StaticResource EditableTextContextMenu}"
                                                    InputScope="Number"
                                                    Text="{Binding SettingsMasterVolumeStepPercentDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                    <i:Interaction.Behaviors>
                                                        <b:HoverInfoPopupBehavior Text="Sets how much each master volume hotkey press changes the default output volume. Use 1 to 100." />
                                                        <b:IntegerOnlyBehavior />
                                                    </i:Interaction.Behaviors>
                                                </TextBox>
                                                <TextBlock
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="{DynamicResource MutedTextBrush}"
                                                    Text="(1 to 100)" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Expander>

                                    <Expander IsExpanded="{Binding SettingsMicVolumeControlsExpanded, Mode=TwoWay}" Style="{StaticResource SettingsVolumeExpanderStyle}">
                                        <Expander.Header>
                                            <TextBlock FontWeight="SemiBold" Text="Microphone Volume" />
                                        </Expander.Header>
                                        <StackPanel>
                                            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                                <Label
                                                    Width="150"
                                                    VerticalAlignment="Center"
                                                    Content="Mic Volume Up:" />
                                                <TextBox
                                                    Width="170"
                                                    ContextMenu="{StaticResource HotkeyDeleteContextMenu}"
                                                    Text="{Binding SettingsMicVolumeUpHotkeyDraftCapture.DisplayText, Mode=OneWay}">
                                                    <i:Interaction.Behaviors>
                                                        <b:PlaceholderExampleBehavior
                                                            Identity="mic-volume-up-hotkey"
                                                            Options="Ctrl+Home|Ctrl+Shift+Up|Alt+WheelUp"
                                                            PreferredFamily="wheel-up" />
                                                        <b:HoverInfoPopupBehavior Text="{Binding SettingsMicVolumeUpHotkeyDraftCapture.HoverText}" WarningKind="{Binding SettingsMicVolumeUpHotkeyDraftCapture.WarningKind}" />
                                                        <b:HotkeyCaptureBehavior Target="{Binding SettingsMicVolumeUpHotkeyDraftCapture}" />
                                                        <b:HotkeyWarningBorderBehavior HasWarning="{Binding SettingsMicVolumeUpHotkeyDraftCapture.HasWarning}" WarningKind="{Binding SettingsMicVolumeUpHotkeyDraftCapture.WarningKind}" />
                                                    </i:Interaction.Behaviors>
                                                </TextBox>
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                                <Label
                                                    Width="150"
                                                    VerticalAlignment="Center"
                                                    Content="Mic Volume Down:" />
                                                <TextBox
                                                    Width="170"
                                                    ContextMenu="{StaticResource HotkeyDeleteContextMenu}"
                                                    Text="{Binding SettingsMicVolumeDownHotkeyDraftCapture.DisplayText, Mode=OneWay}">
                                                    <i:Interaction.Behaviors>
                                                        <b:PlaceholderExampleBehavior
                                                            Identity="mic-volume-down-hotkey"
                                                            Options="Ctrl+End|Ctrl+Shift+Down|Alt+WheelDown"
                                                            PreferredFamily="wheel-down" />
                                                        <b:HoverInfoPopupBehavior Text="{Binding SettingsMicVolumeDownHotkeyDraftCapture.HoverText}" WarningKind="{Binding SettingsMicVolumeDownHotkeyDraftCapture.WarningKind}" />
                                                        <b:HotkeyCaptureBehavior Target="{Binding SettingsMicVolumeDownHotkeyDraftCapture}" />
                                                        <b:HotkeyWarningBorderBehavior HasWarning="{Binding SettingsMicVolumeDownHotkeyDraftCapture.HasWarning}" WarningKind="{Binding SettingsMicVolumeDownHotkeyDraftCapture.WarningKind}" />
                                                    </i:Interaction.Behaviors>
                                                </TextBox>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal">
                                                <Label
                                                    Width="150"
                                                    VerticalAlignment="Center"
                                                    Content="Mic Step (%):" />
                                                <TextBox
                                                    Width="80"
                                                    b:TextBoxPlaceholderBehavior.Text="5"
                                                    ContextMenu="{StaticResource EditableTextContextMenu}"
                                                    InputScope="Number"
                                                    Text="{Binding SettingsMicVolumeStepPercentDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                    <i:Interaction.Behaviors>
                                                        <b:HoverInfoPopupBehavior Text="Sets how much each mic volume hotkey press changes the default microphone volume. Use 1 to 100." />
                                                        <b:IntegerOnlyBehavior />
                                                    </i:Interaction.Behaviors>
                                                </TextBox>
                                                <TextBlock
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="{DynamicResource MutedTextBrush}"
                                                    Text="(1 to 100)" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>

                                <TextBlock Style="{StaticResource SettingsSectionHeaderStyle}" Text="Overlay" />

                                <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                    <CheckBox Content="Enable overlays" IsChecked="{Binding SettingsOverlayEnabledDraft, Mode=TwoWay}">
                                        <i:Interaction.Behaviors>
                                            <b:HoverInfoPopupBehavior Text="Shows on-screen overlays for media, mute, and device switching actions." />
                                        </i:Interaction.Behaviors>
                                    </CheckBox>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                    <Label
                                        Width="150"
                                        VerticalAlignment="Center"
                                        Content="Overlay Position:" />
                                    <ComboBox
                                        Width="170"
                                        IsEnabled="{Binding SettingsOverlayEnabledDraft, Mode=OneWay}"
                                        ItemsSource="{Binding AvailableOverlayPositions}"
                                        SelectedItem="{Binding SettingsOverlayPositionDraft, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Converter={StaticResource EnumDisplayNameConverter}}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,22" Orientation="Horizontal">
                                    <Label
                                        Width="150"
                                        VerticalAlignment="Center"
                                        Content="Overlay Duration (s):" />
                                    <TextBox
                                        Width="80"
                                        b:TextBoxPlaceholderBehavior.Text="2.5"
                                        ContextMenu="{StaticResource EditableTextContextMenu}"
                                        InputScope="Number"
                                        IsEnabled="{Binding SettingsOverlayEnabledDraft, Mode=OneWay}"
                                        Text="{Binding SettingsOverlayDurationSecondsDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                        <i:Interaction.Behaviors>
                                            <b:HoverInfoPopupBehavior Text="How long the overlay stays visible in seconds (0.5 to 10)." />
                                            <b:NumericOnlyBehavior />
                                        </i:Interaction.Behaviors>
                                    </TextBox>
                                    <TextBlock
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource MutedTextBrush}"
                                        Text="(0.5 to 10)" />
                                </StackPanel>

                                <TextBlock Style="{StaticResource SettingsSectionHeaderStyle}" Text="Miscellaneous" />

                                <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                    <CheckBox
                                        Margin="0,0,14,0"
                                        Content="Preserve audio levels"
                                        IsChecked="{Binding SettingsPreserveAudioLevelsDraft, Mode=TwoWay}">
                                        <i:Interaction.Behaviors>
                                            <b:HoverInfoPopupBehavior Text="Preserves current per-process and mixer volume levels when switching output devices." />
                                        </i:Interaction.Behaviors>
                                    </CheckBox>

                                    <CheckBox Content="Auto-scroll to mixer on restore" IsChecked="{Binding SettingsAutoScrollToMixerOnRestoreDraft, Mode=TwoWay}">
                                        <i:Interaction.Behaviors>
                                            <b:HoverInfoPopupBehavior Text="Automatically scrolls to the&#10;&quot;Volume Mixer&quot; when the&#10;app window is restored." />
                                        </i:Interaction.Behaviors>
                                    </CheckBox>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                    <Label
                                        Width="150"
                                        VerticalAlignment="Center"
                                        Content="Device reference:" />
                                    <ComboBox
                                        Width="170"
                                        ItemsSource="{Binding AvailableDeviceReferenceFileModes}"
                                        SelectedItem="{Binding SettingsDeviceReferenceFileModeDraft, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Converter={StaticResource EnumDisplayNameConverter}}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                        <i:Interaction.Behaviors>
                                            <b:HoverInfoPopupBehavior Text="Controls what DEVICES.txt contains: Off disables file generation, Plaintext includes real device IDs and names, and Hashed includes device names with anonymized IDs." />
                                        </i:Interaction.Behaviors>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,22" Orientation="Horizontal">
                                    <Label
                                        Width="150"
                                        VerticalAlignment="Center"
                                        Content="Log Level:" />
                                    <ComboBox
                                        Width="170"
                                        ItemsSource="{Binding AvailableLogLevels}"
                                        SelectedItem="{Binding SettingsLogLevelDraft, Mode=TwoWay}">
                                        <i:Interaction.Behaviors>
                                            <b:HoverInfoPopupBehavior Text="Choose how detailed logs are.&#10;None disables logging and removes&#10;existing log files when applied." />
                                        </i:Interaction.Behaviors>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,22" Orientation="Horizontal">
                                    <CheckBox
                                        Margin="0,0,20,0"
                                        Content="Redact sensitive log content"
                                        IsChecked="{Binding SettingsRedactLogContentDraft, Mode=TwoWay}">
                                        <i:Interaction.Behaviors>
                                            <b:HoverInfoPopupBehavior Text="Enabled keeps sensitive values anonymized in app logs.&#10;Disable this only if you explicitly want raw device names, paths, ids, and similar content written to the log file." />
                                        </i:Interaction.Behaviors>
                                    </CheckBox>
                                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                        <CheckBox
                                            VerticalAlignment="Center"
                                            Content="Enable auto-save"
                                            IsChecked="{Binding SettingsAutoSaveEnabledDraft, Mode=TwoWay}">
                                            <i:Interaction.Behaviors>
                                                <b:HoverInfoPopupBehavior Text="Enable to automatically save device, hotkey, routine, and settings changes." />
                                            </i:Interaction.Behaviors>
                                        </CheckBox>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Button
                                        Width="105"
                                        Margin="0,0,8,0"
                                        Command="{Binding ImportSettingsCommand}"
                                        Content="Import Settings" />
                                    <Button
                                        Width="130"
                                        Margin="0,0,8,0"
                                        Command="{Binding ApplySettingsCommand}"
                                        Content="Apply Settings" />
                                    <Button
                                        Width="105"
                                        Command="{Binding ExportSettingsCommand}"
                                        Content="Export Settings" />
                                </StackPanel>
                            </StackPanel>
                        </TabItem>
                    </TabControl>

                    <StackPanel
                        Margin="10"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Visibility="{Binding IsEditorTabsActive, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button
                            Margin="5"
                            Command="{Binding RefreshDevicesCommand}"
                            Content="Refresh" />
                        <Button
                            Margin="5"
                            Command="{Binding SaveSettingsCommand}"
                            Content="Save Settings" />
                        <CheckBox
                            Margin="5,5,0,5"
                            Content="Run at Startup"
                            IsChecked="{Binding RunAtStartup, Mode=TwoWay}" />
                        <ComboBox
                            Width="70"
                            Margin="9,5,0,5"
                            ItemsSource="{Binding AvailableThemes}"
                            SelectedItem="{Binding Theme, Mode=TwoWay}" />
                    </StackPanel>

                </StackPanel>

                <Label
                    x:Name="VolumeMixerHeader"
                    HorizontalAlignment="Center"
                    Content="{Binding ActiveMixerHeader}"
                    FontSize="18"
                    FontWeight="Bold"
                    Visibility="{Binding IsEditorTabsActive, Converter={StaticResource BoolToVisibilityConverter}}" />

                <StackPanel
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Visibility="{Binding IsEditorTabsActive, Converter={StaticResource BoolToVisibilityConverter}}">
                    <CheckBox
                        Margin="5"
                        Content="Mute Mic"
                        IsChecked="{Binding MuteMic, Mode=TwoWay}" />
                    <CheckBox
                        Margin="5"
                        Content="Deafen"
                        IsChecked="{Binding Deafen, Mode=TwoWay}" />
                    <CheckBox
                        Margin="5"
                        Content="Mute Sound"
                        IsChecked="{Binding MuteSound, Mode=TwoWay}" />
                </StackPanel>

                <ListBox
                    Name="VolumeMixer"
                    Background="Transparent"
                    BorderThickness="0"
                    Focusable="False"
                    IsTabStop="False"
                    ItemsSource="{Binding ActiveMixerSessions}"
                    KeyboardNavigation.TabNavigation="Continue"
                    PreviewMouseWheel="VolumeMixer_PreviewMouseWheel"
                    ScrollViewer.CanContentScroll="True"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    SelectionChanged="VolumeMixer_SelectionChanged"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.ScrollUnit="Pixel"
                    VirtualizingPanel.VirtualizationMode="Recycling"
                    Visibility="{Binding IsEditorTabsActive, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Focusable" Value="False" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Label
                                    Grid.Column="0"
                                    Width="175"
                                    Margin="0,0,20,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                    <i:Interaction.Behaviors>
                                        <b:TrimmedTextPopupBehavior />
                                    </i:Interaction.Behaviors>
                                    <TextBlock
                                        Text="{Binding DisplayName}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap" />
                                    <Label.Style>
                                        <Style BasedOn="{StaticResource {x:Type Label}}" TargetType="{x:Type Label}">
                                            <Setter Property="FontWeight" Value="Normal" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMaster}" Value="True">
                                                    <Setter Property="FontWeight" Value="Bold" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsMic}" Value="True">
                                                    <Setter Property="FontWeight" Value="Bold" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsSystemSounds}" Value="True">
                                                    <Setter Property="FontWeight" Value="Bold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Label.Style>
                                </Label>

                                <Slider
                                    Grid.Column="1"
                                    Width="130"
                                    VerticalAlignment="Center"
                                    IsMoveToPointEnabled="True"
                                    LargeChange="5"
                                    Maximum="100"
                                    SmallChange="1"
                                    Tag="{Binding IsMuted}"
                                    Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <i:Interaction.Behaviors>
                                        <b:SliderValuePopupBehavior HorizontalOffset="0" VerticalOffset="-28" />
                                        <b:SliderThumbRightClickBehavior Command="{Binding DataContext.ActiveMixer.ToggleMuteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}" />
                                        <b:SliderKeyboardAccelerationBehavior MuteCommand="{Binding DataContext.ActiveMixer.ToggleMuteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" MuteCommandParameter="{Binding}" />
                                    </i:Interaction.Behaviors>
                                </Slider>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel
                    Margin="8,1,0,10"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Visibility="{Binding IsEditorTabsActive, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button
                        Margin="2"
                        Command="{Binding ResetToDefaultsCommand}"
                        Content="Reset to Defaults"
                        Style="{StaticResource ResetButtonStyle}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <tb:TaskbarIcon
            x:Name="taskbarIcon"
            ContextMenu="{x:Null}"
            IconSource="pack://application:,,,/Images/sound.ico"
            ToolTipText="AudioPilot"
            TrayMouseDoubleClick="TaskbarIcon_TrayMouseDoubleClick"
            TrayRightMouseUp="TaskbarIcon_TrayRightMouseUp" />
    </Grid>
</Window>
